{
  "name": "creators-ai-hologram-boxing",
  "version": "1.0.0",
  "private": true,
  "description": "Creators AI Hologram Boxing Event website",
  "scripts": {
    "start": "python3 scripts/dev-server.py",
    "start:static": "python3 -m http.server 8080",
    "deploy:vercel": "vercel --prod",
    "deploy:netlify": "netlify deploy --prod --dir=.",
    "meta:verify": "node scripts/meta/meta-ads-cli.js verify",
    "meta:list": "node scripts/meta/meta-ads-cli.js list",
    "meta:plan": "node scripts/meta/meta-ads-cli.js plan",
    "meta:create-waitlist": "node scripts/meta/meta-ads-cli.js create-waitlist",
    "meta:create-test-ad": "node scripts/meta/meta-ads-cli.js create-test-ad",
    "generate:brief003-vo": "node --env-file=.env.local scripts/generate-brief003-vo.mjs"
  },
  "dependencies": {
    "@elevenlabs/elevenlabs-js": "^2.56.0"
  }
}
