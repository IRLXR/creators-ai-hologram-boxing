{
  "version": 2,
  "name": "creators-ai-hologram-boxing",
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1.js" },
    { "src": "/landing", "dest": "/landing.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
